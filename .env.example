# Homebite environment variables
# Copy this file to `.env` and fill in your own values. `.env` is gitignored.

# --- Google Gemini (required) ---
# Direct Gemini API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional: override the text model (defaults to gemini-2.0-flash for better free-tier RPM)
# GEMINI_MODEL=gemini-2.0-flash
# Optional: override the vision/OCR model (defaults to gemini-2.5-flash for receipt photos)
# GEMINI_VISION_MODEL=gemini-2.5-flash
# Optional: max Gemini calls per minute in-process (default 4, stays under free-tier 5/min)
# GEMINI_MAX_CALLS_PER_MINUTE=4
# Optional: conversational AI step rewrite for MealDB recipes (costs 1 extra API call each)
# ENABLE_AI_STEP_REWRITE=false

# --- TheMealDB (optional) ---
# Defaults to the free test key "1". Set this to your paid key to lift limits.
# MEALDB_API_KEY=1

# --- Pexels (optional) ---
# Free photo API used to find a dish photo when TheMealDB has no match.
# Get a key at https://www.pexels.com/api/. Without it, recipes with no
# MealDB match fall back to a branded placeholder image.
# PEXELS_API_KEY=

# --- Firebase (needed later for auth + saving recipes/pantry) ---
# These use the VITE_ prefix so they are readable in the browser, as Firebase
# web config is public by design. Fill in when wiring up auth.
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
